    "date-fns": "^3.6.0",
    "execa": "^9.3.0",
    "gray-matter": "^4.0.3",
    "ink": "^5.1.4",
    "inquirer": "^10.3.1",
    "js-yaml": "^4.1.0",
    "keytar": "^7.9.0",
    "open": "^10.1.0",
    "ora": "^8.0.1",
    "react": "^18.3.1",
    "simple-git": "^3.24.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "prettier": "^3.3.3",
