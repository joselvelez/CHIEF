# ============================================================
# CHIEF — .gitignore template
#
# INSTRUCTIONS:
# Copy this file to .gitignore in your repo root before
# adding any personal files or credentials.
#
#   cp .gitignore_example .gitignore
#   git add .gitignore
#   git commit -m "add gitignore"
#
# Secrets and credentials MUST NEVER be committed to this
# repo. This file is the enforcement layer for that rule.
# The .gitignore_example file itself IS committed — it is
# a template, not a live gitignore.
# ============================================================

# ----------------------------------
# Secrets & Credentials (NEVER commit)
# ----------------------------------
.env
.env.*
*.env
/secrets/
secrets.yaml
secrets.json
*.key
*.pem
*.p12
*.pfx
*.token
*.secret
*_secret*
*_token*
*_credentials*
credentials.json
token.json
client_secret*.json
service_account*.json

# ----------------------------------
# OS Keychain / local auth stores
# ----------------------------------
.keychain
.netrc
.npmrc
.pypirc

# ----------------------------------
# HELM local config (machine-specific, not shared)
# ----------------------------------
.helm-local/
*.helm-local

# ----------------------------------
# Node / HELM CLI build artifacts
# ----------------------------------
node_modules/
dist/
build/
.cache/
*.tgz

# ----------------------------------
# Python (if any runners use Python)
# ----------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
venv/
env/
.venv/
*.egg-info/
.eggs/

# ----------------------------------
# OS junk
# ----------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ----------------------------------
# Editor / IDE
# ----------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
*.orig

# ----------------------------------
# Temporary / scratch files
# ----------------------------------
*.tmp
*.bak
*.backup
scratch/
_scratch/
*.local.log
/tmp/

# ----------------------------------
# NOTE: /logs/ is intentionally NOT ignored.
# Committed logs in /logs/[user]/ are part of the
# audit trail and should be version-controlled.
# Only raw local runtime logs (*.local.log) are excluded.
# ----------------------------------
